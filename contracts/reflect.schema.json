{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memory-server.nousresearch.com/contracts/reflect.schema.json",
  "title": "reflect — MCP Tool Schema",
  "description": "Analyse the belief store and produce structured insights about what the agent currently believes.",
  "version": "0.7.0",
  "api_version": "0.7.0",
  "schema_version": "1.0.0",

  "tool": {
    "name": "reflect",
    "description": "Analyse the belief store: overview, contradictions, decay, topics, evidence_audit, confidence"
  },

  "input": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["overview", "contradictions", "decay", "topics", "evidence_audit", "confidence"],
        "description": "Analysis mode",
        "default": "overview"
      },
      "topic": {
        "type": "string",
        "description": "Optional topic/tag filter"
      },
      "min_confidence": {
        "type": "number",
        "description": "Minimum confidence threshold 0.0-1.0",
        "minimum": 0,
        "maximum": 1,
        "default": 0.0
      },
      "limit": {
        "type": "integer",
        "description": "Maximum number of beliefs to analyse (0 = all)",
        "minimum": 0,
        "default": 50
      }
    },
    "additionalProperties": false
  },

  "output": {
    "type": "object",
    "description": "Mode-dependent result dict. All modes return a JSON object with at least a `mode` field.",
    "properties": {
      "mode": {
        "type": "string",
        "description": "The mode that was executed"
      }
    }
  },

  "output_definitions": {
    "overview": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["overview"] },
        "total_beliefs": { "type": "integer" },
        "by_lifecycle_state": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "by_topics": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "confidence": {
          "type": "object",
          "properties": {
            "high_0.8_1.0": { "type": "integer" },
            "medium_0.5_0.8": { "type": "integer" },
            "low_0.0_0.5": { "type": "integer" },
            "average": { "type": "number" }
          }
        },
        "contradiction_count": { "type": "integer" },
        "stale_count": { "type": "integer" },
        "decaying_next_7d": { "type": "integer" },
        "no_evidence_count": { "type": "integer" },
        "oldest_belief_days": { "type": "number" },
        "newest_belief_days": { "type": "number" }
      }
    },
    "contradictions": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["contradictions"] },
        "total": { "type": "integer" },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "belief_a_id": { "type": "string" },
              "proposition_a": { "type": "string" },
              "confidence_a": { "type": "number" },
              "belief_b_id": { "type": "string" },
              "proposition_b": { "type": "string" },
              "confidence_b": { "type": "number" },
              "overlap_score": { "type": "number" },
              "detected_at": { "type": "string" }
            }
          }
        },
        "recommendation": { "type": "string" }
      }
    },
    "decay": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["decay"] },
        "stale_now": { "type": "integer" },
        "stale_7d": { "type": "integer" },
        "archived_7d": { "type": "integer" },
        "forgotten_7d": { "type": "integer" },
        "by_tag_stale": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "recommendation": { "type": "string" }
      }
    },
    "topics": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["topics"] },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tag": { "type": "string" },
              "count": { "type": "integer" },
              "avg_confidence": { "type": "number" },
              "stale": { "type": "integer" }
            }
          }
        },
        "untagged_count": { "type": "integer" }
      }
    },
    "evidence_audit": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["evidence_audit"] },
        "total": { "type": "integer" },
        "with_evidence": { "type": "integer" },
        "without_evidence": { "type": "integer" },
        "avg_evidence_per_belief": { "type": "number" },
        "by_source_type": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "zero_weight_entries": { "type": "integer" },
        "recommendation": { "type": "string" }
      }
    },
    "confidence": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["confidence"] },
        "beliefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "proposition": { "type": "string" },
              "confidence": { "type": "number" },
              "evidence_count": { "type": "integer" },
              "lifecycle_state": { "type": "string" }
            }
          }
        },
        "histogram": {
          "type": "object",
          "properties": {
            "0.9_1.0": { "type": "integer" },
            "0.7_0.9": { "type": "integer" },
            "0.5_0.7": { "type": "integer" },
            "0.3_0.5": { "type": "integer" },
            "0.0_0.3": { "type": "integer" }
          }
        },
        "lowest_count": { "type": "integer" },
        "recommendation": { "type": "string" }
      }
    }
  },

  "errors": {
    "$ref": "common.schema.json#/definitions/error_envelope"
  }
}
